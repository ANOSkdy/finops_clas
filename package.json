{
  "name": "clas-finops",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:tax-schedule": "tsx --test tests/tax-schedule.test.ts",
    "smoke:local": "node scripts/smoke-local.mjs",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed-development.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "@radix-ui/react-dialog": "1.1.15",
    "bcryptjs": "3.0.3",
    "dotenv": "16.6.1",
    "next": "16.1.0",
    "pg": "8.16.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.0",
    "prisma": "7.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
